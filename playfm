#!/bin/sh

# Written by Mikael Jakhelln.
# Simplified for the piradio Raspberry Pi Zero appliance by Tomas Gal and ChatGPT.
#
# 2026 maintenance note:
#   This wrapper was reduced during a maintenance pass roughly six years after
#   the Raspbian Buster appliance build. The historical generic player supported
#   folders, URLs, pipes, YouTube, wav/m4a fallbacks, avconv/ffmpeg paths, and
#   playback control commands. The deployed radio only needs one path:
#
#       MP3 file -> sox -> PiFM
#
# Usage:
#   sh /pifmplay "/radio_nas/file.mp3"
#   sh /pifmplay "/radio_nas/file.mp3" 100.0
#
# Repository note:
#   This file is named playfm in the repository. In the appliance deployment it
#   was installed as /pifmplay.

INPUT="$1"
FREQUENCY="${2:-100.0}"

SOX="/usr/bin/sox"
PIFM="/pifm"

if [ -z "$INPUT" ]; then
    echo "Usage: sh /pifmplay /path/to/file.mp3 [frequency]" >&2
    exit 2
fi

if [ ! -r "$INPUT" ]; then
    echo "Cannot read input file: $INPUT" >&2
    exit 1
fi

if [ ! -x "$PIFM" ]; then
    echo "PiFM binary not executable: $PIFM" >&2
    exit 1
fi

"$SOX" -v 0.9 -t mp3 "$INPUT" -t wav --input-buffer 80000 -r 22050 -c 1 - | "$PIFM" - "$FREQUENCY"
